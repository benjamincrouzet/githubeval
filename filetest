pipeline {
    agent any

    stages {
	stage('Create-container-myapp') {
	    steps {
		sh 'docker run -d --name myapp --hostname myapp -v volumemyapp:/var/www/html mon-nginx'
		sh 'docker ps && docker exec myapp ifconfig'
	    }	
	}
	stage('Copy-monsite') {
	    steps {
		sh 'cp -rf ./monsite/ ./volumemyapp'
	    }
	}
    }
}